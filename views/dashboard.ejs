<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Dashboard</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>

  <body>
    <div class="container wide">
      <nav class="navbar">
        <ul class="navbar-links">
          <li><a href="/dashboard">Dashboard</a></li>
          <li><a href="/fitness">Fitness</a></li>
          <li><a href="/diet">Diet</a></li>
          <li><a href="/goals">Goals</a></li>
          <li><a href="/profile">Profile</a></li>
        </ul>
      </nav>

    <div class="container wide">
      <h1>Welcome, <%= username %>!</h1>
      <hr>

      <!-- Profile Info -->
      <h2>Your Profile</h2>
      <label>Gender: <%= gender %></label>
      <label>Age: <%= age %></label>
      <label>Weight: <%= weight %> kg</label>
      <label>Height: <%= height %> cm</label>
      <label>BMI: <%= bmi %> — 
        <%= bmi < 18.5 ? "Underweight" : bmi < 25 ? "Healthy" : bmi < 30 ? "Overweight" : "Obese" %>
      </label>
      <hr>

      <!-- Today's Summary -->
      <h2>Today's Summary</h2>
      <table>
        <tr>
          <th>Steps Today</th>
          <th>Calories Today</th>
          <th>Workout Today</th>
        </tr>
        <tr>
        <td><%= typeof totalSteps !== "undefined" ? totalSteps : 0 %> steps</td>
        <td><%= typeof totalCalories !== "undefined" ? totalCalories : 0 %> kcal</td>
          <td><%= typeof workout !== "undefined" && workout ? "Logged ✓" : "Not logged yet" %></td>
        </tr>
      </table>
      <hr>

      <!-- Quick Actions -->
      <h2>Quick Actions</h2>
      <div class="btn-group">
        <a href="/diet"><button>Log Meal</button></a>
        <a href="/fitness"><button>Log Workout</button></a>
        <a href="/steps"><button>Log Steps</button></a>
      </div>
      <hr>

      <a href="/logout">Logout</a>
    </div>
  </body>
</html>