<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Dashboard</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>

  <body>
    <nav class="navbar">
      <ul class="navbar-links">
        <li><a href="/dashboard">Dashboard</a></li>
        <li><a href="/fitness">Fitness</a></li>
        <li><a href="/workout">Workout</a></li>
      </ul>
    </nav>
    <div class="container">
    <div class="profile-section">
  <img src="/default-profile.png" class="profile-pic" />

  <h2><%= username || "User" %></h2>
  <p><%= typeof email !== 'undefined' ? email : 'No email' %></p>

  <input type="file" id="uploadPic" />
  </div>
    <h1>Welcome to your home page, <%= username %>!</h1>
    <hr>
    <label for="gender">Gender: <%= gender %></label>
    <label for="age">Age: <%= age %></label>
    <label for="weight">Weight: <%= weight %></label>
    <label for="height">Height: <%= height %></label>
    <label>BMI: <%= bmi %> — <%= bmi < 18.5 ? "Underweight" : bmi < 25 ? "Healthy" : bmi < 30 ? "Overweight" : "Obese" %></label>
    <hr>



      <a href="/logout">Logout</a>
    </div>
  </body>
</html>
