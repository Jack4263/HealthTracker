<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Exercise Log</title>
    <link rel="stylesheet" href="/styles.css" >
  </head>

  <body>
    <div class="container">
      <h1>Exercise Tracking</h1>
      <p>Log your workouts and monitor your fitness progress.</p>
      <!-- Exercise tracking content goes here -->
      <hr>
      <a href="/dashboard">Back to Dashboard</a>

      <h2>Log Exercise</h2>
      <form action="/exercise" method="post">
        <label for="activity"><b>Exercise Type</b></label>
        <input id="activity" type="text" placeholder="Enter Exercise Type e.g. Running" name="activity" required />

        <label for="duration"><b>Duration (minutes)</b></label>
        <input id="duration" type="number" placeholder="Enter Duration e.g. 30" name="duration" min="1" required />

        <Label for="steps"><b>Steps (optional)</b></label>
        <input id="steps" type="number" placeholder="Enter Steps e.g. 1000" name="steps" min="0" />

        <label for="date"><b>Date</b></label>
        <input id="date" type="date" name="date" required />

        <button type="submit">Log Exercise</button>
      </form>
      <hr>
        <h2>Exercise History</h2>
        <% if (logs.length === 0) { %>
          <p>No exercise logs yet.</p>
        <% } else { %>
          <table>
            <thead>
              <tr>
                <th>Activity</th>
                <th>Duration (minutes)</th>
                <th>Steps</th>
                <th>Date</th>
              </tr>
            </thead>
            <tbody>
              <% logs.forEach(log => { %>
                <tr>
                  <td><%= log.activity %></td>
                  <td><%= log.duration %></td>
                  <td><%= log.steps || 0 %></td>
                  <td><%= log.date %></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        <% } %>
    </div>
  </body>
</html>