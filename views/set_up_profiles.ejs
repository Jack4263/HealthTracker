<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Health Tracker - Set up your profile</title>
        <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <div class="container">
      <h1>Welcome <%= username %>!</h1>
      <p>Fill in the information below to set up your profile.</p>
      <hr />
      <form action="/set_up_profile" method="post">
        <label for="gender"><b>Gender</b></label>
        <select id="gender" name="gender" required>
          <option value="">Select Gender</option>
          <option value="male">Male</option>
          <option value="female">Female</option>
          <option value="other">Other</option>
          <option value="prefer_not_to_say">Prefer not to say</option>
        </select>

        <label for="age"><b>Age</b></label>
        <input id="age" type="number" placeholder="Enter Age" name="age" min="1" required />

        <label for="weight"><b>Weight (kg)</b></label>
        <input id="weight" type="number" placeholder="Enter Weight" name="weight" min="1" required />

        <label for="height"><b>Height (cm)</b></label>
        <input id="height" type="number" placeholder="Enter Height" name="height" min="1" required />

        <button type="submit">Save profile</button>
      </form>
    </div>
  </body>
</html>
