<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Steps</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>

  <body>
    <div class="container wide">
    <nav class="navbar">
      <ul class="navbar-links">
        <li><a href="/dashboard">Dashboard</a></li>
        <li><a href="/fitness">Fitness</a></li>
        <li><a href="/diet">Diet</a></li>
      </ul>
    </nav>
    <h1>Step Tracker</h1>
    <p><b>Date:</b> <%= steps.date %></p>

    <hr />
    
    <h2>Add Steps</h2>
    <form method="POST" action="/steps">
      <input type="hidden" name="steps_id" value="<%= steps.id %>" />

      <div>
        <label for="steps_distance"><b>Distance:</b></label><br />
        <input
          id="steps_distance"
          name="exercise_name"
          type="text"
          required
        />
      </div>

      <div>
        <label>(Steps are calculated via your recorded height and distance)</label><br />

      </div>


      <br />
      <button type="submit">Log Steps</button>
    </form>

    <hr />

    <h2>Step Logs Today</h2>

    <% if (!entries || entries.length === 0) { %>
      <p>No steps logged today</p>
    <% } else { %>
      <table border="1" cellpadding="6">
        <thead>
          <tr>
            <th>Estimated Steps</th>
            <th>Distance</th>
          </tr>
        </thead>
        <tbody>
          <% entries.forEach(steps => { %>
            <tr>
              <td><%= steps.estimated %></td>
              <td><%= steps.distance ?? "" %></td>

              <td>
                <form method="POST" action="/steps/delete/<%= steps.id %>">
                  <input type="hidden" name="steps_id" value="<%= steps.id %>" />
                  <button type="submit">Delete</button>
                </form>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    <% } %>

    <hr />
    <a href="/fitness">Back to Fitness</a>
  </body>
</html>